{
  "name": "@partygame/worker",
  "version": "0.0.1",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "deploy": "npm run build-admin && wrangler deploy",
    "build-admin": "cd ../admin && npm run build && cd ../.. && node scripts/generate-admin-index.js && rm -rf apps/worker/admin-dist && mkdir -p apps/worker/admin-dist/admin && cp -r apps/admin/build/* apps/worker/admin-dist/admin/",
    "generate-sdk": "ts-node scripts/generate-sdk.ts"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@partygame/shared": "file:../../packages/shared",
    "arctic": "^3.7.0",
    "hono": "^4.12.21",
    "in-app-purchase": "^1.11.4",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260519.1",
    "@types/in-app-purchase": "^1.11.4",
    "@types/node": "^25.9.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.112.0"
  }
}
