<!-- ========== COST CALCULATOR SCRIPT ========== -->
<script>
  const clamp = (v: number, lo: number, hi: number) => Math.min(hi, Math.max(lo, v));

  // Real pricing model (same formulas as test/benchmarks/run.test.ts)
  // PartyGame: Cloudflare Workers Free tier + R2 + DO
  // Nakama:    AWS EC2 c7g.xlarge + CockroachDB + Shield Advanced
  const CF_WORKERS_PER_1M = 0.30;
  const CF_DO_PER_1M = 0.15;
  const CF_DAILY_FREE = 100_000;
  const NK_EC2_HR = 0.145;
  const NK_COCKROACH_HR = 0.145;
  const NK_SHIELD = 3000;

  function calcCosts(ccu) {
    // PartyGame
    const monthlyReqs = ccu * 1000 * 30;
    const billable = Math.max(0, monthlyReqs - CF_DAILY_FREE * 30) / 1_000_000;
    const pg = (billable * CF_WORKERS_PER_1M + (ccu * 500 * 30) / 1_000_000 * CF_DO_PER_1M + 2 * 0.015).toFixed(0);

    // Nakama
    const instances = Math.max(1, Math.ceil(ccu / 300));
    const nk = (instances * NK_EC2_HR * 24 * 30 + NK_COCKROACH_HR * 24 * 30 + 0.0225 * 24 * 30 + ccu * 0.15 * 0.09 + NK_SHIELD).toFixed(0);

    return { pg: Number(pg), trad: Number(nk) };
  }

  function formatUSD(n: number) {
    return n.toLocaleString("en-US", { style: "currency", currency: "USD", minimumFractionDigits: 0 });
  }

  function formatCCU(n: number) {
    return n.toLocaleString("en-US");
  }

  function updateUI(ccu: number) {
    const costs = calcCosts(ccu);
    const savings = costs.trad - costs.pg;
    const pct = costs.trad > 0 ? Math.round((savings / costs.trad) * 100) : 0;

    // Display
    const ccuDisp = document.getElementById("ccu-display");
    const pgCost = document.getElementById("pg-cost");
    const tradCost = document.getElementById("trad-cost");
    const savingsPct = document.getElementById("savings-pct");
    const savingsAbs = document.getElementById("savings-abs");
    const pgBar = document.getElementById("pg-bar");
    const tradBar = document.getElementById("trad-bar");

    if (ccuDisp) ccuDisp.textContent = formatCCU(ccu);
    if (pgCost) pgCost.textContent = formatUSD(costs.pg);
    if (tradCost) tradCost.textContent = formatUSD(costs.trad);
    if (savingsPct) savingsPct.textContent = String(pct);
    if (savingsAbs) savingsAbs.textContent = formatUSD(savings);

    // Bars (scale to Nakama cost)
    const maxBar = Math.max(1000, costs.trad);
    if (pgBar) pgBar.style.width = `${Math.max(1, (costs.pg / maxBar) * 100)}%`;
    if (tradBar) tradBar.style.width = `${Math.max(1, (costs.trad / maxBar) * 100)}%`;
  }

  const slider = document.getElementById("ccu-slider") as HTMLInputElement | null;
  if (slider) {
    slider.addEventListener("input", () => {
      updateUI(Number(slider.value));
    });
    // Initial render
    updateUI(Number(slider.value));
  }
</script>
