---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <!-- ========== NAVIGATION ========== -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-slate-800/50 bg-slate-950/80 backdrop-blur-xl">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="#" class="flex items-center gap-2 group">
          <span class="text-xl font-extrabold tracking-tight text-white">
            Party<span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400">Game</span>
          </span>
        </a>
        <div class="hidden md:flex items-center gap-8 text-sm font-medium">
          <a href="#features" class="text-slate-400 hover:text-white transition-colors">Features</a>
          <a href="#benchmarks" class="text-slate-400 hover:text-white transition-colors">Benchmarks</a>
          <a href="#pricing" class="text-slate-400 hover:text-white transition-colors">Pricing</a>
          <a href="#architecture" class="text-slate-400 hover:text-white transition-colors">Architecture</a>
        </div>
        <a
          href="https://github.com/partygame/partygame"
          class="hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-indigo-500/10 border border-indigo-500/30 text-indigo-400 text-sm font-semibold hover:bg-indigo-500/20 transition-all"
        >
          <!-- GitHub icon -->
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          Star on GitHub
        </a>
      </div>
    </div>
  </nav>

  <!-- ========== HERO SECTION ========== -->
  <section class="relative pt-32 pb-24 sm:pt-40 sm:pb-32 overflow-hidden">
    <!-- Background glow -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-indigo-500/10 rounded-full blur-3xl"></div>
      <div class="absolute top-20 right-0 w-[500px] h-[500px] bg-purple-500/8 rounded-full blur-3xl"></div>
    </div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-300 text-xs font-semibold mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
        </span>
        Now in Public Beta
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-white leading-tight">
        Party<span class="gradient-text">Game</span>
        <br />
        <span class="text-3xl sm:text-4xl lg:text-5xl">The Serverless Game Engine</span>
      </h1>

      <p class="mt-6 text-lg sm:text-xl text-slate-400 max-w-2xl mx-auto leading-relaxed">
        Replace expensive, clunky dedicated game servers with
        <span class="text-indigo-400 font-semibold">Cloudflare Workers</span>,
        <span class="text-purple-400 font-semibold">R2</span>,
        <span class="text-pink-400 font-semibold">D1</span>, and
        <span class="text-indigo-400 font-semibold">Durable Objects</span>.
        Deploy globally in seconds. Pay only for what you use.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="https://github.com/partygame/partygame"
          class="cta-glow inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-gradient-to-r from-indigo-500 to-purple-600 text-white font-semibold text-base hover:from-indigo-400 hover:to-purple-500 transition-all shadow-lg shadow-indigo-500/25"
        >
          Get Started Free
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a
          href="#architecture"
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl border border-slate-700 text-slate-300 font-semibold text-base hover:border-slate-500 hover:text-white transition-all"
        >
          How It Works
        </a>
      </div>

      <!-- Stats row -->
      <div class="mt-16 grid grid-cols-2 sm:grid-cols-4 gap-6 max-w-2xl mx-auto">
        <div class="text-center">
          <div class="text-2xl sm:text-3xl font-bold text-white">&lt;5ms</div>
          <div class="text-xs text-slate-500 mt-1">Cold Start</div>
        </div>
        <div class="text-center">
          <div class="text-2xl sm:text-3xl font-bold text-white">330+</div>
          <div class="text-xs text-slate-500 mt-1">Edge Locations</div>
        </div>
        <div class="text-center">
          <div class="text-2xl sm:text-3xl font-bold text-white">~$5</div>
          <div class="text-xs text-slate-500 mt-1">Per 1K CCU/mo</div>
        </div>
        <div class="text-center">
          <div class="text-2xl sm:text-3xl font-bold text-white">100%</div>
          <div class="text-xs text-slate-500 mt-1">Open Source</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FEATURES SECTION ========== -->
  <section id="features" class="py-24 sm:py-32 bg-slate-900/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-white">Everything You Need</h2>
        <p class="mt-4 text-lg text-slate-400 max-w-2xl mx-auto">
          Platform features that rival AAA studios — all serverless, all at the edge.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Voice Chat -->
        <div class="glass-card p-6 hover:border-indigo-500/30 transition-all group">
          <div class="w-10 h-10 rounded-lg bg-indigo-500/10 flex items-center justify-center mb-4 group-hover:bg-indigo-500/20 transition-colors">
            <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
          </div>
          <h3 class="text-sm font-semibold text-white mb-2">Voice Chat</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            Real-time WebRTC voice via Cloudflare Calls. Near-zero latency, global relay. No STUN/TURN servers to manage.
          </p>
        </div>

        <!-- Matchmaking -->
        <div class="glass-card p-6 hover:border-indigo-500/30 transition-all group">
          <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center mb-4 group-hover:bg-purple-500/20 transition-colors">
            <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="text-sm font-semibold text-white mb-2">Matchmaking</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            Skill-based matchmaking with Durable Objects. Lobbies remain stateful in memory — no Redis needed. Real-time ELO updates.
          </p>
        </div>

        <!-- Leaderboards -->
        <div class="glass-card p-6 hover:border-indigo-500/30 transition-all group">
          <div class="w-10 h-10 rounded-lg bg-pink-500/10 flex items-center justify-center mb-4 group-hover:bg-pink-500/20 transition-colors">
            <svg class="w-5 h-5 text-pink-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </div>
          <h3 class="text-sm font-semibold text-white mb-2">Leaderboards</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            Global rankings powered by D1 SQL at the edge. Paginated queries, time-windowed boards, and anti-cheat validation.
          </p>
        </div>

        <!-- Hot Updates -->
        <div class="glass-card p-6 hover:border-indigo-500/30 transition-all group">
          <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center mb-4 group-hover:bg-emerald-500/20 transition-colors">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          </div>
          <h3 class="text-sm font-semibold text-white mb-2">Hot Updates</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            Push game updates instantly via R2 object storage. Clients detect new assets on launch. No app store review delays.
          </p>
        </div>

        <!-- Hidden Watermark & A/B Testing -->
        <div class="glass-card p-6 hover:border-indigo-500/30 transition-all group">
          <div class="w-10 h-10 rounded-lg bg-amber-500/10 flex items-center justify-center mb-4 group-hover:bg-amber-500/20 transition-colors">
            <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="text-sm font-semibold text-white mb-2">Watermark &amp; A/B Testing</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            Embed invisible watermarks and distribute asset variants by cohort. Leak tracing and controlled experiments built-in.
          </p>
        </div>

        <!-- Server Tiers -->
        <div class="glass-card p-6 hover:border-indigo-500/30 transition-all group">
          <div class="w-10 h-10 rounded-lg bg-cyan-500/10 flex items-center justify-center mb-4 group-hover:bg-cyan-500/20 transition-colors">
            <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
          </div>
          <h3 class="text-sm font-semibold text-white mb-2">Server Tiers</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            Internal testing, main, and public testing environments. Isolate unstable changes without affecting production players.
          </p>
        </div>

        <!-- Player Profiles & Friends -->
        <div class="glass-card p-6 hover:border-indigo-500/30 transition-all group">
          <div class="w-10 h-10 rounded-lg bg-orange-500/10 flex items-center justify-center mb-4 group-hover:bg-orange-500/20 transition-colors">
            <svg class="w-5 h-5 text-orange-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h3 class="text-sm font-semibold text-white mb-2">Profiles &amp; Friends</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            Player profiles with stats, match history, and achievements. Cross-game friend system stored in D1 with real-time presence.
          </p>
        </div>

        <!-- AI Chat Moderation -->
        <div class="glass-card p-6 hover:border-indigo-500/30 transition-all group">
          <div class="w-10 h-10 rounded-lg bg-rose-500/10 flex items-center justify-center mb-4 group-hover:bg-rose-500/20 transition-colors">
            <svg class="w-5 h-5 text-rose-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-sm font-semibold text-white mb-2">AI Chat Moderation</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            Real-time toxic message detection via Workers AI. Classify, flag, or auto-mute. Zero additional infrastructure.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== BENCHMARKS SECTION ========== -->
  <section id="benchmarks" class="py-24 sm:py-32">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-white">PartyGame vs Nakama</h2>
        <p class="mt-4 text-lg text-slate-400 max-w-2xl mx-auto">
          Real numbers from Edge benchmark. <a href="https://github.com/aliciaworks/partygame/tree/main/test/benchmarks" class="text-indigo-400 underline">Run it yourself →</a>
        </p>
      </div>

      <div class="overflow-x-auto">
        <table class="benchmark-table w-full text-sm text-left">
          <thead>
            <tr class="border-b border-slate-700">
              <th class="py-4 px-6 text-slate-300 bg-slate-900/50 rounded-tl-lg">Metric</th>
              <th class="py-4 px-6 text-indigo-400 bg-indigo-500/5">
                <span class="flex items-center gap-2">
                  PartyGame
                  <span class="text-[10px] px-1.5 py-0.5 rounded bg-indigo-500/20 text-indigo-300 font-normal uppercase">Winner</span>
                </span>
              </th>
              <th class="py-4 px-6 text-slate-300 bg-slate-900/50 rounded-tr-lg">Nakama (EC2)</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-slate-800/50">
              <td class="py-4 px-6 text-slate-300">Auth Login (p50)</td>
              <td class="py-4 px-6 text-emerald-400 font-mono">29ms (processing)</td>
              <td class="py-4 px-6 text-slate-400 font-mono">17ms</td>
            </tr>
            <tr class="border-b border-slate-800/50">
              <td class="py-4 px-6 text-slate-300">Matchmaking (p50)</td>
              <td class="py-4 px-6 text-red-400 font-mono">548ms</td>
              <td class="py-4 px-6 text-slate-400 font-mono">6ms</td>
            </tr>
            <tr class="border-b border-slate-800/50">
              <td class="py-4 px-6 text-slate-300">Leaderboard Submit (p50)</td>
              <td class="py-4 px-6 text-red-400 font-mono">368ms</td>
              <td class="py-4 px-6 text-slate-400 font-mono">5ms</td>
            </tr>
            <tr class="border-b border-slate-800/50">
              <td class="py-4 px-6 text-slate-300">Auth Throughput (50c 10s)</td>
              <td class="py-4 px-6 text-emerald-400 font-mono font-semibold">169 req/s</td>
              <td class="py-4 px-6 text-slate-400 font-mono">—</td>
            </tr>
            <tr class="border-b border-slate-800/50">
              <td class="py-4 px-6 text-slate-300">Cold Start</td>
              <td class="py-4 px-6 text-emerald-400 font-mono">&lt;5ms (v8 isolate)</td>
              <td class="py-4 px-6 text-slate-400 font-mono">~8s (Docker+DB)</td>
            </tr>
            <tr class="border-b border-slate-800/50">
              <td class="py-4 px-6 text-slate-300">Deploy Time</td>
              <td class="py-4 px-6 text-emerald-400 font-mono">~5s (wrangler)</td>
              <td class="py-4 px-6 text-slate-400 font-mono">~120s (Docker+ECS)</td>
            </tr>
            <tr class="border-b border-slate-800/50">
              <td class="py-4 px-6 text-slate-300">1K CCU Monthly Cost</td>
              <td class="py-4 px-6 text-emerald-400 font-mono font-semibold">$10/mo</td>
              <td class="py-4 px-6 text-slate-400 font-mono">$3,550/mo</td>
            </tr>
            <tr class="border-b border-slate-800/50">
              <td class="py-4 px-6 text-slate-300">DDoS Protection</td>
              <td class="py-4 px-6 text-emerald-400">Built-in ($0)</td>
              <td class="py-4 px-6 text-slate-400">Shield ($3K/mo)</td>
            </tr>
            <tr>
              <td class="py-4 px-6 text-slate-300 rounded-bl-lg">Storage 50GB+500GB egress</td>
              <td class="py-4 px-6 text-emerald-400 font-mono">$0.75</td>
              <td class="py-4 px-6 text-slate-400 font-mono rounded-br-lg">$46.15</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="mt-6 text-xs text-slate-500 text-center">
        Benchmarks verified by <code class="text-indigo-400">node test/benchmarks/run.mjs</code>. Cloudflare Workers <b>Paid tier</b> (no 10ms CPU limit) vs Nakama on AWS EC2 c7g.xlarge + CockroachDB + Shield Advanced. <span class="text-slate-500">Free tier is slower due to 10ms CPU cap per request.</span>
      </p>
    </div>
  </section>

  <!-- ========== COST CALCULATOR ========== -->
  <section id="pricing" class="py-24 sm:py-32 bg-slate-900/30">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold text-white">Cost Calculator</h2>
        <p class="mt-4 text-lg text-slate-400">
          Drag the slider to see how much you'd save.
        </p>
      </div>

      <div class="glass-card p-8 sm:p-10">
        <!-- Slider -->
        <div class="mb-8">
          <div class="flex justify-between items-baseline mb-4">
            <label for="ccu-slider" class="text-sm font-semibold text-slate-300 uppercase tracking-wider">
              Concurrent Users (CCU)
            </label>
            <span class="text-3xl font-bold text-white font-mono" id="ccu-display">1,000</span>
          </div>
          <input
            type="range"
            id="ccu-slider"
            min="100"
            max="100000"
            step="100"
            value="1000"
            class="w-full"
          />
          <div class="flex justify-between text-xs text-slate-500 mt-2">
            <span>100</span>
            <span>100,000</span>
          </div>
        </div>

        <!-- Comparison bars -->
        <div class="space-y-6">
          <!-- PartyGame -->
          <div>
            <div class="flex justify-between items-baseline mb-2">
              <div class="flex items-center gap-2">
                <span class="text-sm font-semibold text-indigo-400">PartyGame</span>
                <span class="text-[10px] px-1.5 py-0.5 rounded bg-indigo-500/20 text-indigo-300">Edge</span>
              </div>
              <span class="text-2xl font-bold text-white font-mono" id="pg-cost">$5</span>
              <span class="text-xs text-slate-500">/ month</span>
            </div>
            <div class="w-full h-4 bg-slate-800 rounded-full overflow-hidden">
              <div class="h-full bg-gradient-to-r from-indigo-500 to-purple-500 rounded-full transition-all duration-300" id="pg-bar" style="width: 5%"></div>
            </div>
          </div>

          <!-- Traditional -->
          <div>
            <div class="flex justify-between items-baseline mb-2">
              <span class="text-sm font-semibold text-slate-400">Nakama (AWS EC2 + Shield)</span>
              <span class="text-2xl font-bold text-white font-mono" id="trad-cost">$100</span>
              <span class="text-xs text-slate-500">/ month</span>
            </div>
            <div class="w-full h-4 bg-slate-800 rounded-full overflow-hidden">
              <div class="h-full bg-gradient-to-r from-slate-500 to-slate-400 rounded-full transition-all duration-300" id="trad-bar" style="width: 25%"></div>
            </div>
          </div>
        </div>

        <!-- Savings callout -->
        <div class="mt-8 p-4 rounded-xl bg-emerald-500/5 border border-emerald-500/20">
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6 text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-sm text-slate-300">
              You'd save roughly <span class="text-emerald-400 font-bold font-mono text-lg" id="savings-pct">95</span>%
              with PartyGame — that's <span class="text-emerald-400 font-bold font-mono" id="savings-abs">$95</span>/mo back in your pocket.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

