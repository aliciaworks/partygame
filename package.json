{
  "name": "partygame",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "fixtures/*",
    "clients/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "test": "vitest run",
    "format": "prettier --check .",
    "generate:types": "npm run generate:types --workspace=@partygame/shared"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "vitest": "^3.0.0",
    "typescript-eslint": "^8.32.0",
    "typescript": "^5.4.5"
  }
}
