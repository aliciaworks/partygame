{
  "name": "partygame",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "engines/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "test": "vitest run",
    "format": "prettier --check .",
    "generate:types": "npm run generate:types --workspace=@partygame/shared",
    "generate-sdk": "npx @openapitools/openapi-generator-cli generate -i openapi.yaml -g csharp -o sdks/unity --additional-properties=targetFramework=net472,packageName=PartyGameSDK"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.0",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "vitest": "^4.1.6",
    "typescript-eslint": "^8.59.4",
    "typescript": "^6.0.3"
  }
}
